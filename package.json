{
  "name": "@41px/xmind-skill",
  "version": "3.0.0",
  "description": "Claude Code / Claude Desktop skill for creating and reading XMind mind maps",
  "repository": {
    "type": "git",
    "url": "https://github.com/apeyroux/mcp-xmind"
  },
  "homepage": "https://github.com/apeyroux/mcp-xmind#readme",
  "keywords": [
    "xmind",
    "mindmap",
    "skill",
    "claude-code",
    "claude-desktop"
  ],
  "license": "MIT",
  "author": "Alexandre Peyroux <alex@fmap.it>",
  "scripts": {
    "build:skill": "bash scripts/build-skill.sh",
    "test:create": "echo '{\"path\":\"/tmp/test.xmind\",\"sheets\":[{\"title\":\"T\",\"rootTopic\":{\"title\":\"R\"}}]}' | node skills/xmind/scripts/create_xmind.mjs",
    "test:read": "echo '{\"action\":\"read\",\"path\":\"/tmp/test.xmind\"}' | node skills/xmind/scripts/read_xmind.mjs",
    "test": "python3 tests/test_roundtrip.py && python3 tests/test_complex.py && python3 tests/test_edge_cases.py"
  }
}
